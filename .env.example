# Copy to `.env` and fill in. `.env` is gitignored.

# ESIOS (Red Eléctrica) personal token — only needed to REFRESH the energy
# dashboard data with `npm run build:energy`. Request a free token by email:
#   https://www.esios.ree.es/en/page/api
ESIOS_API_KEY=your_esios_token_here

# Gemini key (optional; used by the AI Studio tooling).
GEMINI_API_KEY=your_gemini_key_here
